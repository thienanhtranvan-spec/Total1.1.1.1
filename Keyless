local menuOpen = false
local minimized = false
local function toggleMenu()
    menuOpen = not menuOpen
    MF.Visible = menuOpen
    if menuOpen and ActiveTab ~= "" then renderTab(ActiveTab) end
end

connectBtn(XBtn, toggleMenu)
connectBtn(OpenBtn, toggleMenu)
connectBtn(MinBtn, function()
    minimized = not minimized
    SideBar.Visible = not minimized
    CF.Visible = not minimized
    MF.Size = minimized and UDim2.new(0, 560, 0, 46) or UDim2.new(0, 560, 0, 520)
end)

local function clickFirst()
    local name = nil
    for n, _ in pairs(Pages) do name = n break end
    if name then
        local tb = TabBtns[name]
        if tb then
            tb.accent.Visible = true
            tb.btn:FindFirstChildOfClass("TextLabel").TextColor3 = T.Text
            ActiveTab = name
            renderTab(name)
        end
    end
end
clickFirst()

