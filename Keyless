local function restoreStats()
    local h = GetH()
    if h then
        if speedLocked then h.WalkSpeed = savedSpeed end
        if jumpLocked then h.JumpPower = savedJump end
        notify("🔄 Đã khôi phục Speed/Jump")
    end
end

