local function MakeFarESP(player)
    if player == Player then return end
    local function createESP(character)
        if not character then return end
        local root = character:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local old = ESPFolder:FindFirstChild("ESP_" .. player.Name)
        if old then old:Destroy() end
        local bb = mk("BillboardGui", {Name = "ESP_" .. player.Name, Adornee = root, AlwaysOnTop = true, Size = UDim2.new(0, 140, 0, 48), StudsOffset = Vector3.new(0, 2.5, 0), MaxDistance = 9e9, Parent = ESPFolder})
        mk("TextLabel", {Size = UDim2.new(1, 0, 0.5, 0), BackgroundTransparency = 1, Text = player.Name, TextColor3 = Color3.fromRGB(255, 100, 120), TextStrokeTransparency = 0, TextScaled = true, Font = Enum.Font.GothamBold, Parent = bb})
        local hpBg = mk("Frame", {Size = UDim2.new(0.85, 0, 0.22, 0), Position = UDim2.new(0.075, 0, 0.6, 0), BackgroundColor3 = Color3.fromRGB(40, 40, 55), BorderSizePixel = 0, Parent = bb})
        cr(hpBg, 3)
        local hpBar = mk("Frame", {Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = Color3.fromRGB(0, 255, 100), BorderSizePixel = 0, Parent = hpBg})
        cr(hpBar, 3)
        local hpConn
        hpConn = RS.Heartbeat:Connect(function()
            if not player.Character or not player.Character.Parent then if hpConn then hpConn:Disconnect() end return end
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                hpBar.Size = UDim2.new(pct, 0, 1, 0)
                if pct > 0.6 then hpBar.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
                elseif pct > 0.3 then hpBar.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
                else hpBar.BackgroundColor3 = Color3.fromRGB(255, 50, 50) end
            end
        end)
    end
    if player.Character then createESP(player.Character) end
    player.CharacterAdded:Connect(function(char) task.wait(0.5) createESP(char) end)
end

