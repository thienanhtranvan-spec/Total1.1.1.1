    addInput("WalkSpeed", "Nhập số (16+)", "Set", function(v)
        local n = tonumber(v)
        if n then
            SpeedVal = n
            local h = GetH()
            if h then h.WalkSpeed = n end
        end
    end, function() SpeedVal = 16 notify("🔄 Reset speed") end)
    addButton("Apply Speed", nil, function()
        local h = GetH()
        if h then
            h.WalkSpeed = SpeedVal
            notify("✅ Speed: " .. SpeedVal)
        end
    end)
    addInput("JumpPower", "Nhập số (50+)", "Set", function(v)
        local n = tonumber(v)
        if n then
            JumpVal = n
            local h = GetH()
            if h then h.JumpPower = n end
        end
    end, function() JumpVal = 50 notify("🔄 Reset jump") end)
    addButton("Apply Jump", nil, function()
        local h = GetH()
        if h then
            h.JumpPower = JumpVal
            notify("✅ Jump: " .. JumpVal)
        end
    end)
    addSep("Lưu & Khôi Phục")
    addButton("💾 Lưu Speed", nil, saveSpeed)
    addButton("💾 Lưu Jump", nil, saveJump)
    addButton("🔄 Khôi Phục", nil, restoreStats)
    addSep("Chức Năng")
    addToggle("infj", "Infinite Jump", "Nhảy vô hạn", function(s)
        if s then
            C("infj")
            Conn.infj = UIS.JumpRequest:Connect(function()
                local h = GetH()
                if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
            end)
        else
            C("infj")
        end
    end)
    addToggle("fly", "Fly", "Bay tự do WASD + Space/Shift", function(s)
        if s then
            local r = GetR()
            if not r then return end
            local bg = Instance.new("BodyGyro", r)
            bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            bg.D = 100
            bg.Name = "FlyG"
            local bv = Instance.new("BodyVelocity", r)
            bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            bv.Name = "FlyV"
            C("fly")
            Conn.fly = RS.Heartbeat:Connect(function()
                local r2 = GetR()
                if not r2 then return end
                local bg2 = r2:FindFirstChild("FlyG")
                local bv2 = r2:FindFirstChild("FlyV")
                if not bg2 or not bv2 then return end
                bg2.CFrame = workspace.CurrentCamera.CFrame
                local d = Vector3.new()
                if UIS:IsKeyDown(Enum.KeyCode.W) then d = d + workspace.CurrentCamera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.S) then d = d - workspace.CurrentCamera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.A) then d = d - workspace.CurrentCamera.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.D) then d = d + workspace.CurrentCamera.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.Space) then d = d + Vector3.new(0, 1, 0) end
                if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then d = d - Vector3.new(0, 1, 0) end
                bv2.Velocity = d * 60
            end)
        else
            C("fly")
            local r = GetR()
            if r then
                if r:FindFirstChild("FlyG") then r.FlyG:Destroy() end
                if r:FindFirstChild("FlyV") then r.FlyV:Destroy() end
            end
            local h = GetH()
            if h then h.PlatformStand = false end
        end
    end)
    addToggle("nc", "Noclip", "Xuyên tường", function(s)
        if s then
            C("nc")
            Conn.nc = RS.Stepped:Connect(function()
                local c = Player.Character
                if c then
                    for _, p in c:GetDescendants() do
                        if p:IsA("BasePart") then p.CanCollide = false end
                    end
                end
            end)
        else
            C("nc")
            local c = Player.Character
            if c then
                for _, p in c:GetDescendants() do
                    if p:IsA("BasePart") then p.CanCollide = true end
                end
            end
        end
    end)
    addToggle("af", "Anti Fall", "Chống chết vì ngã", function(s)
        if s then
            C("af")
            Conn.af = RS.Heartbeat:Connect(function()
                local h = GetH()
                if h and h.FloorMaterial == Enum.Material.Air then
                    h:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end)
        else
            C("af")
        end
    end)
    addToggle("av", "Anti Void", "Chống rơi xuống void", function(s)
        if s then
            C("av")
            Conn.av = RS.Heartbeat:Connect(function()
                local r = GetR()
                if r and r.Position.Y < -80 then
                    r.CFrame = CFrame.new(r.Position.X, 50, r.Position.Z)
                end
            end)
        else
            C("av")
        end
    end)
    addToggle("lg", "Low Gravity", "Trọng lực thấp", function(s)
        workspace.Gravity = s and 30 or 196.2
    end)
    addButton("Reset Character", nil, function()
        local h = GetH()
        if h then h.Health = 0 end
    end)
end)

addTab("Teleport", "🌀", function()
    addSep("Nhanh")
    addButton("TP to Spawn", nil, function()
        local r = GetR()
        if not r then return end
        local sp = workspace:FindFirstChildOfClass("SpawnLocation")
        if sp then r.CFrame = sp.CFrame + Vector3.new(0, 5, 0) notify("✅ TP Spawn!") end
    end)
    addButton("TP Map Center", nil, function()
        local r = GetR()
        if r then r.CFrame = CFrame.new(0, 50, 0) notify("✅ TP Center!") end
    end)
    addButton("TP Random Player", nil, function()
        local list = {}
        for _, p in Players:GetPlayers() do
            if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                table.insert(list, p)
            end
        end
        if #list > 0 then
            local p = list[math.random(1, #list)]
            local r = GetR()
            if r then
                r.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                notify("✅ TP tới " .. p.Name)
            end
        else
            notify("❌ Không có ai!")
        end
    end)
    addSep("TP theo tên")
    addInput("TP tới Player", "Nhập tên (1 chữ cũng được)", "TP", function(v)
        local found = {}
        for _, p in Players:GetPlayers() do
            if p ~= Player and p.Name:lower():find(v:lower(), 1, true) then
                table.insert(found, p)
            end
        end
        if #found == 0 then
            notify("❌ Không tìm thấy: " .. v)
        elseif #found > 1 then
            local names = ""
            for _, p in found do names = names .. p.Name .. " " end
            notify("⚠ Trùng: " .. names .. "→ ghi thêm!")
        else
            local p = found[1]
            local r = GetR()
            if r and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                r.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                notify("✅ TP tới " .. p.Name)
            end
        end
    end, nil)
    addSep("Server & Lưu")
    addInput("TP Server ID", "Dán Server ID", "TP", function(v)
        if v ~= "" then
            pcall(function() TS:TeleportToPlaceInstance(game.PlaceId, v, Player) end)
        end
    end, nil)
    addTPSave()
end)
