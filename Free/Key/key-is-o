local function MakeFarESP(player)
    if player == Player then return end
    
    local function createESP(character)
        if not character then return end
        local root = character:FindFirstChild("HumanoidRootPart")
        if not root then return end
        
        local old = ESPFolder:FindFirstChild("ESP_" .. player.Name)
        if old then old:Destroy() end
        
        local bb = Instance.new("BillboardGui")
        bb.Name = "ESP_" .. player.Name
        bb.Adornee = root
        bb.AlwaysOnTop = true
        bb.Size = UDim2.new(0, 140, 0, 48)
        bb.StudsOffset = Vector3.new(0, 3, 0)
        bb.MaxDistance = 9e9
        bb.Parent = ESPFolder
        
        local nameLabel = Instance.new("TextLabel", bb)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
        nameLabel.Text = player.Name
        nameLabel.TextColor3 = Color3.fromRGB(255, 100, 120)
        nameLabel.TextStrokeTransparency = 0
        nameLabel.TextScaled = true
        nameLabel.Font = Enum.Font.GothamBold
        
        local hpBarBg = Instance.new("Frame", bb)
        hpBarBg.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
        hpBarBg.Size = UDim2.new(0.85, 0, 0.22, 0)
        hpBarBg.Position = UDim2.new(0.075, 0, 0.6, 0)
        hpBarBg.BorderSizePixel = 0
        
        local hpBarCorner = Instance.new("UICorner")
        hpBarCorner.CornerRadius = UDim.new(0, 3)
        hpBarCorner.Parent = hpBarBg
        
        local hpBar = Instance.new("Frame", hpBarBg)
        hpBar.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        hpBar.Size = UDim2.new(1, 0, 1, 0)
        hpBar.BorderSizePixel = 0
        
        local hpFillCorner = Instance.new("UICorner")
        hpFillCorner.CornerRadius = UDim.new(0, 3)
        hpFillCorner.Parent = hpBar
        
        local hpConn
        hpConn = RS.Heartbeat:Connect(function()
            if not player.Character or not player.Character.Parent then
                if hpConn then hpConn:Disconnect() end
                return
            end
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                local percent = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                hpBar.Size = UDim2.new(percent, 0, 1, 0)
                if percent > 0.6 then
                    hpBar.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
                elseif percent > 0.3 then
                    hpBar.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
                else
                    hpBar.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
                end
            end
        end)
    end
    
    if player.Character then
        createESP(player.Character)
    end
    
    player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        createESP(char)
    end)
end

local function toggleESP()
    espEnabled = not espEnabled
    if espEnabled then
        for _, p in pairs(Players:GetPlayers()) do
            MakeFarESP(p)
        end
        Players.PlayerAdded:Connect(MakeFarESP)
        if language == "VN" then
            Player:Chat("[ESP] 👁️ ESP ĐÃ BẬT - XA VÔ TẬN")
        else
            Player:Chat("[ESP] 👁️ ESP ENABLED - INFINITE RANGE")
        end
    else
        ESPFolder:ClearAllChildren()
        if language == "VN" then
            Player:Chat("[ESP] 👁️ ESP ĐÃ TẮT")
        else
            Player:Chat("[ESP] 👁️ ESP DISABLED")
        end
    end
    if espBtn then
        if language == "VN" then
            espBtn.Text = espEnabled and "✅ TẮT ESP" or "👁️ BẬT ESP"
        else
            espBtn.Text = espEnabled and "✅ DISABLE ESP" or "👁️ ENABLE ESP"
        end
    end
end

local function saveSpeed()
    local hum = Player.Character and Player.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        savedSpeed = hum.WalkSpeed
        speedLock = true
        if language == "VN" then
            Player:Chat("[ESP] 💾 ĐÃ LƯU SPEED: " .. savedSpeed)
            speedBtn.Text = "✅ KHÓA SPEED"
        else
            Player:Chat("[ESP] 💾 SPEED SAVED: " .. savedSpeed)
            speedBtn.Text = "✅ SPEED LOCKED"
        end
    else
        if language == "VN" then
            Player:Chat("[ESP] ❌ KHÔNG TÌM THẤY NHÂN VẬT")
        else
            Player:Chat("[ESP] ❌ CHARACTER NOT FOUND")
        end
    end
end

