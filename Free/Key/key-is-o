local function restoreStats()
    local hum = Player.Character and Player.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        if speedLock then
            hum.WalkSpeed = savedSpeed
            if language == "VN" then
                Player:Chat("[ESP] 🔄 ĐÃ KHÔI PHỤC SPEED: " .. savedSpeed)
            else
                Player:Chat("[ESP] 🔄 SPEED RESTORED: " .. savedSpeed)
            end
        end
        if jumpLock then
            hum.JumpPower = savedJump
            if language == "VN" then
                Player:Chat("[ESP] 🔄 ĐÃ KHÔI PHỤC JUMP: " .. savedJump)
            else
                Player:Chat("[ESP] 🔄 JUMP RESTORED: " .. savedJump)
            end
        end
    end
end

Player.CharacterAdded:Connect(function(char)
