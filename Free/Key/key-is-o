local dragging = false
local dragStart, startPos

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MenuFrame.Position
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        menuPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        MenuFrame.Position = menuPos
    end
end)

UIS.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.Insert then
        if authenticated then
            toggleMenu()
        end
    end
end)

local function showNotify(msg, isError)
    local notif = Instance.new("Frame")
    notif.Size = UDim2.new(0, 280, 0, 45)
    notif.Position = UDim2.new(0.5, -140, 0, 60)
    notif.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    notif.BackgroundTransparency = 0.05
    notif.BorderSizePixel = 0
    notif.Parent = ScreenGui
    
    local notifCorner = Instance.new("UICorner")
    notifCorner.CornerRadius = UDim.new(0, 10)
    notifCorner.Parent = notif
    
    local notifStroke = Instance.new("UIStroke")
    notifStroke.Color = isError and Color3.fromRGB(255, 80, 80) or Color3.fromRGB(80, 255, 120)
    notifStroke.Thickness = 1
    notifStroke.Parent = notif
    
    local text = Instance.new("TextLabel", notif)
    text.Size = UDim2.new(1, -20, 1, 0)
    text.Position = UDim2.new(0, 10, 0, 0)
    text.BackgroundTransparency = 1
    text.Text = msg
    text.TextColor3 = Color3.fromRGB(255, 255, 255)
    text.TextSize = 12
    text.Font = Enum.Font.Gotham
    
    TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Position = UDim2.new(0.5, -140, 0, 20)}):Play()
    task.wait(2.5)
    TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Position = UDim2.new(0.5, -140, 0, -60)}):Play()
    task.wait(0.3)
    notif:Destroy()
end

local function activate()
    authenticated = true
    LangFrame.Visible = false
    KeyFrame.Visible = false
    MenuFrame.Visible = true
    
    local playerName = Player.Name
    if language == "VN" then
        showNotify("✅ KEY ĐÚNG! CHÚC " .. playerName:upper() .. " CHƠI GAME VUI VẺ!")
    else
        showNotify("✅ KEY CORRECT! WISH " .. playerName:upper() .. " HAVE FUN!")
    end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player then
            MakeFarESP(p)
        end
    end
    
    Players.PlayerAdded:Connect(function(p)
        if p ~= Player and espEnabled then
            MakeFarESP(p)
        end
    end)
end

